{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/vip/cron/sign-in",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/vip/cron/refresh-token",
      "schedule": "30 */2 * * *"
    }
  ]
}
